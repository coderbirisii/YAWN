{
    "endpoints": [
        {
            "method": "GET",
            "name": "Player Titles",
            "url": "https://valorant-api.com/v1/playertitles",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {5}",
                        "uuid string",
                        "displayName string (localized)",
                        "titleText string (localized)",
                        "isHiddenIfNotOwned boolean",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data of all player title"
        },
        {
            "method": "GET",
            "name": "Player Title by Uuid",
            "url": "https://valorant-api.com/v1/playertitles/{playertitleUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {5}",
                        "uuid string",
                        "displayName string (localized)",
                        "titleText string (localized)",
                        "isHiddenIfNotOwned boolean",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data of the requested player title"
        }
    ]
}