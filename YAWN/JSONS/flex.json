{
    "endpoints": [
        {
            "method": "GET",
            "name": "Flex",
            "url": "https://valorant-api.com/v1/flex",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {5}",
                        "uuid string",
                        "displayName string (localized)",
                        "displayNameAllCaps string (localized)",
                        "displayIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all in-game flex"
        },
        {
            "method": "GET",
            "name": "Flex by Uuid",
            "url": "https://valorant-api.com/v1/flex/{flexUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {5}",
                        "uuid string",
                        "displayName string (localized)",
                        "displayNameAllCaps string (localized)",
                        "displayIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets the requested in-game flex"
        }
    ]
}