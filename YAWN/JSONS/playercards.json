{
    "endpoints": [
        {
            "method": "GET",
            "name": "Player Cards",
            "url": "https://valorant-api.com/v1/playercards",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {9}",
                        "uuid string",
                        "displayName string (localized)",
                        "isHiddenIfNotOwned boolean",
                        "themeUuid string",
                        "displayIcon string",
                        "smallArt string",
                        "wideArt string",
                        "largeArt string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all player cards"
        },
        {
            "method": "GET",
            "name": "Player Card by Uuid",
            "url": "https://valorant-api.com/v1/playercards/{playercardUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {9}",
                        "uuid string",
                        "displayName string (localized)",
                        "isHiddenIfNotOwned boolean",
                        "themeUuid string",
                        "displayIcon string",
                        "smallArt string",
                        "wideArt string",
                        "largeArt string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of the requested player card"
        }
    ]
}