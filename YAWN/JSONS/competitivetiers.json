{
    "endpoints": [
        {
            "method": "GET",
            "name": "Competitive Tiers",
            "url": "https://valorant-api.com/v1/competitivetiers",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {4}",
                        "uuid string",
                        "assetObjectName string",
                        "tiers object[] {10}",
                        "tier int32",
                        "tierName string (localized)",
                        "division string",
                        "divisionName string (localized)",
                        "color string",
                        "backgroundColor string",
                        "smallIcon string",
                        "largeIcon string",
                        "rankTriangleDownIcon string",
                        "rankTriangleUpIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all competitive tiers"
        },
        {
            "method": "GET",
            "name": "Competitive Tier by Uuid",
            "url": "https://valorant-api.com/v1/competitivetiers/{competitivetierUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {4}",
                        "uuid string",
                        "assetObjectName string",
                        "tiers object[] {10}",
                        "tier int32",
                        "tierName string (localized)",
                        "division string",
                        "divisionName string (localized)",
                        "color string",
                        "backgroundColor string",
                        "smallIcon string",
                        "largeIcon string",
                        "rankTriangleDownIcon string",
                        "rankTriangleUpIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets the requested competitive tier table"
        }
    ]
}