{
    "endpoints": [
        {
            "method": "GET",
            "name": "Events",
            "url": "https://valorant-api.com/v1/events",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {6}",
                        "uuid string",
                        "displayName string (localized)",
                        "shortDisplayName string (localized)",
                        "startTime dateTime",
                        "endTime dateTime",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all events"
        },
        {
            "method": "GET",
            "name": "Event by Uuid",
            "url": "https://valorant-api.com/v1/events/{eventUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {6}",
                        "uuid string",
                        "displayName string (localized)",
                        "shortDisplayName string (localized)",
                        "startTime dateTime",
                        "endTime dateTime",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets the requested event"
        }
    ]
}