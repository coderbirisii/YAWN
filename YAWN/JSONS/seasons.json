            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {8}",
                        "uuid string",
                        "displayName string (localized)",
                        "title string (localized)",
                        "type string",
                        "startTime dateTime",
                        "endTime dateTime",
                        "parentUuid string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data of all seasons"
