{
    "endpoints": [
        {
            "method": "GET",
            "name": "Content Tiers",
            "url": "https://valorant-api.com/v1/contenttiers",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {9}",
                        "uuid string",
                        "displayName string (localized)",
                        "devName string",
                        "rank int32",
                        "juiceValue int32",
                        "juiceCost int32",
                        "highlightColor string",
                        "displayIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all content tiers"
        },
        {
            "method": "GET",
            "name": "Content Tier by Uuid",
            "url": "https://valorant-api.com/v1/contenttiers/{contenttierUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {9}",
                        "uuid string",
                        "displayName string (localized)",
                        "devName string",
                        "rank int32",
                        "juiceValue int32",
                        "juiceCost int32",
                        "highlightColor string",
                        "displayIcon string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets the requested content tier"
        }
    ]
}