<UserControl x:Class="YAWN.Controls.WeaponInventoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             x:Name="Self"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
	<Border Background="#181E34" CornerRadius="20" Margin="10" Padding="10">
		<Border.Effect>
			<DropShadowEffect BlurRadius="5" ShadowDepth="3" />
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>
			
			<Image Grid.Row="0" Source="{Binding SkinImage, ElementName=Self}"
			       ToolTip="{Binding SkinName, ElementName=Self}"
			       ToolTipService.InitialShowDelay="0" Margin="5">
				<Image.Effect>
					<DropShadowEffect BlurRadius="5" ShadowDepth="3" />
				</Image.Effect>
			</Image>
			
			<Border Grid.Row="1" Background="#252A40" CornerRadius="10" 
			        Padding="5" Margin="5,0,5,5"
			        Visibility="{Binding BuddyVisibility, ElementName=Self}">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="30"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					
					<Image Grid.Column="0" Source="{Binding BuddyImage, ElementName=Self}"
					       Width="25" Height="25"
					       ToolTip="{Binding BuddyName, ElementName=Self}"
					       ToolTipService.InitialShowDelay="0"/>
					
					<TextBlock Grid.Column="1" Text="{Binding BuddyName, ElementName=Self}"
					           Foreground="White" FontSize="10" 
					           VerticalAlignment="Center" Margin="5,0,0,0"
					           TextTrimming="CharacterEllipsis"/>
				</Grid>
			</Border>
		</Grid>
	</Border>
</UserControl>
