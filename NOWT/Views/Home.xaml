<UserControl
	x:Class="NOWT.Views.Home"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:c="clr-namespace:NOWT.Controls"
	xmlns:viewmodels="clr-namespace:NOWT.ViewModels"
	xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
	xmlns:p="clr-namespace:NOWT.Properties"
	xmlns:fa="http://schemas.fontawesome.com/icons/fonts"
	d:DataContext="{d:DesignInstance Type=viewmodels:HomeViewModel}"
	d:DesignHeight="754"
	d:DesignWidth="1536"
	mc:Ignorable="d">
	<i:Interaction.Triggers>
		<i:EventTrigger EventName="Loaded">
			<i:InvokeCommandAction Command="{Binding PassiveLoadCheckCommand}" />
		</i:EventTrigger>
		<i:EventTrigger EventName="Closing">
			<i:InvokeCommandAction Command="{Binding StopPassiveLoadAsyncCommand}" />
		</i:EventTrigger>
	</i:Interaction.Triggers>
	<UserControl.Resources>
	</UserControl.Resources>
	<UserControl.Triggers>
		<EventTrigger RoutedEvent="Loaded">
			<BeginStoryboard>
				<Storyboard>
					<DoubleAnimation
						Storyboard.TargetProperty="Opacity"
						From="0.0" To="1.0" Duration="0:0:1" />
				</Storyboard>
			</BeginStoryboard>
		</EventTrigger>
	</UserControl.Triggers>

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="60" />
			<RowDefinition />
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<Grid Grid.Row="0" Grid.ColumnSpan="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="*" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Button
				Grid.Column="0" Cursor="Hand" Width="60" Height="60"
				HorizontalAlignment="Left" VerticalAlignment="Center"
				Command="{Binding DataContext.NavigateSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
				Template="{StaticResource ButtonTemplate}">

				<fa:ImageAwesome PrimaryColor="#007EF9" Icon="Solid_Gear" Margin="10" />
			</Button>

			<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" Visibility="Collapsed">
				<!-- Queue Info -->
				<StackPanel Orientation="Horizontal" Margin="5,0">
					<Image Source="{Binding CurrentQueueImage}" Height="30" Width="30" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality">
						<Image.Effect>
							<DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
						</Image.Effect>
					</Image>
					<TextBlock Text="{Binding CurrentQueueName}" Foreground="White" FontSize="28" VerticalAlignment="Center" FontWeight="SemiBold">
						<TextBlock.Effect>
							<DropShadowEffect BlurRadius="3" ShadowDepth="2" Opacity="0.8"/>
						</TextBlock.Effect>
					</TextBlock>
				</StackPanel>

				<!-- Shard Info -->
				<StackPanel Orientation="Horizontal" Margin="25,0">
					<fa:ImageAwesome Icon="Solid_EarthAmericas" PrimaryColor="White" Height="25" Width="25" Margin="0,0,10,0">
						<fa:ImageAwesome.Effect>
							<DropShadowEffect BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
						</fa:ImageAwesome.Effect>
					</fa:ImageAwesome>
					<TextBlock Text="{Binding CurrentShardName}" Foreground="White" FontSize="28" VerticalAlignment="Center" FontWeight="SemiBold">
						<TextBlock.Effect>
							<DropShadowEffect BlurRadius="3" ShadowDepth="2" Opacity="0.8"/>
						</TextBlock.Effect>
					</TextBlock>
				</StackPanel>

				<!-- Map Card -->
				<Border CornerRadius="12" Margin="20,0" Width="220" Height="50" ClipToBounds="True">
					<Border.Effect>
						<DropShadowEffect BlurRadius="10" ShadowDepth="4" Opacity="0.6"/>
					</Border.Effect>
					<Grid>
						<Image Source="{Binding CurrentMapImage}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
						<Border Background="#60000000"/>
						<TextBlock Text="{Binding CurrentMapName}" Foreground="White" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold">
							<TextBlock.Effect>
								<DropShadowEffect BlurRadius="3" ShadowDepth="2" Opacity="1"/>
							</TextBlock.Effect>
						</TextBlock>
					</Grid>
				</Border>

				<TextBlock Text="Support For all Game Modes" Foreground="#40FFFFFF" FontSize="12" VerticalAlignment="Bottom" Margin="10,0,0,5" FontStyle="Italic"/>
			</StackPanel>

			<Button
				Grid.Column="0" x:Name="GoMatch"
				Command="{Binding DataContext.NavigateMatchCommand, RelativeSource={RelativeSource AncestorType=Window}}"
				Visibility="Collapsed" />

			<Button
				Grid.Row="0" Grid.Column="4" Cursor="Hand" Width="60" Height="60"
				HorizontalAlignment="Right"
				Command="{Binding DataContext.NavigateInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
				Template="{StaticResource ButtonTemplate}">
				<fa:ImageAwesome PrimaryColor="#007EF9" Icon="Solid_Info" Margin="10" />
			</Button>
			<TextBlock Grid.Row="0" Grid.Column="2" HorizontalAlignment="Left" FontSize="35" VerticalAlignment="Center"
			           FontWeight="SemiBold" FontFamily="{StaticResource Nunito}"
			           Foreground="White" Text="{x:Static p:Resources.YourParty}" Margin="10,0"/>

			<TextBlock FontSize="35" VerticalAlignment="Center" HorizontalAlignment="Right"
			           FontWeight="SemiBold" Grid.Row="0" Grid.Column="3" FontFamily="{StaticResource Nunito}"
			           Foreground="White" Text="{x:Static p:Resources.Status}" Margin="10,0"/>
		</Grid>

		<ItemsControl Grid.Row="1" Grid.Column="0" Margin="0,15,0,0" VerticalAlignment="Center"
		              ItemsSource="{Binding PlayerList}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<UniformGrid Columns="1" Margin="5" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate>
					<c:PlayerControl MaxHeight="150"
					                 Margin="0 5"
					                 PlayerCell="{Binding}" />
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>


		<Grid Grid.Row="1" Grid.Column="1" x:Name="Grid">

			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>


			<StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
			            Orientation="Horizontal">
				<Border Background="#252A40" Margin="20" Width="Auto"
				        CornerRadius="20">
					<Border.Effect>
						<DropShadowEffect BlurRadius="5" ShadowDepth="3" />
					</Border.Effect>
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition />
							<RowDefinition />
							<RowDefinition />
							<RowDefinition />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>
						<TextBlock Margin="25" Grid.Row="1" Grid.Column="0"
						           FontSize="20"
						           HorizontalAlignment="Center"
						           FontFamily="{StaticResource Nunito}"
						           VerticalAlignment="Center"
						           FontWeight="Normal"
						           Foreground="White"
						           Text="{x:Static p:Resources.Valorant}" />
						<fa:ImageAwesome Height="30" Width="30" x:Name="ValorantStatusView"
						                 Grid.Row="1" Grid.Column="1" PrimaryColor="#ff4654"
						                 Icon="Solid_Xmark" Margin="25" />

						<TextBlock Margin="25"
						           Grid.Row="0" Grid.Column="0"
						           FontSize="20"
						           HorizontalAlignment="Center"
						           VerticalAlignment="Center"
						           FontFamily="{StaticResource Nunito}"
						           FontWeight="Normal"
						           Foreground="White"
						           Text="Riot Client" />
						<fa:ImageAwesome Height="30" Width="30" x:Name="RiotStatusView"
						                 Grid.Row="0" Grid.Column="1" PrimaryColor="#ff4654"
						                 Icon="Solid_Xmark" Margin="25" />

						<TextBlock Margin="25" Grid.Row="2" Grid.Column="0"
						           FontSize="20"
						           HorizontalAlignment="Center"
						           VerticalAlignment="Center"
						           FontFamily="{StaticResource Nunito}"
						           FontWeight="Normal"
						           Foreground="White"
						           Text="{x:Static p:Resources.Account}" />
						<fa:ImageAwesome Height="30" Width="30" x:Name="AccountStatusView"
						                 Grid.Row="2" Grid.Column="1" PrimaryColor="#ff4654"
						                 Icon="Solid_Xmark" Margin="25" />
						<TextBlock Margin="25" Grid.Row="3" Grid.Column="0"
						           FontSize="20"
						           HorizontalAlignment="Center"
						           VerticalAlignment="Center"
						           FontFamily="{StaticResource Nunito}"
						           FontWeight="Normal"
						           Foreground="White"
						           Text="{x:Static p:Resources.Match}" />
						<fa:ImageAwesome Height="30" Width="30" x:Name="MatchStatusView"
						                 Grid.Row="3" Grid.Column="1" PrimaryColor="#ff4654"
						                 Icon="Solid_Xmark" Margin="25" />
					</Grid>
				</Border>

				<Border Background="#252A40" Margin="20" Width="Auto" Height="Auto" VerticalAlignment="Center"
				        CornerRadius="20">
					<Border.Effect>
						<DropShadowEffect BlurRadius="5" ShadowDepth="3" />
					</Border.Effect>
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition />
							<ColumnDefinition />
						</Grid.ColumnDefinitions>
						<!-- <TextBlock Margin="25" -->
						<!--            FontSize="20" -->
						<!--            HorizontalAlignment="Center" -->
						<!--            VerticalAlignment="Center" -->
						<!--            FontFamily="{StaticResource Nunito}" -->
						<!--            FontWeight="Normal" -->
						<!--            Foreground="White" -->
						<!--            Text="{x:Static p:Resources.QueueTime}" /> -->
						<!-- <TextBlock Margin="25" -->
						<!--            FontSize="20" Grid.Row="0" Grid.Column="1" -->
						<!--            HorizontalAlignment="Center" -->
						<!--            FontFamily="{StaticResource Nunito}" -->
						<!--            VerticalAlignment="Center" -->
						<!--            FontWeight="Normal" -->
						<!--            Foreground="#007EF9" -->
						<!--            Text="{Binding QueueTime}" /> -->
						<TextBlock Margin="25" Grid.Column="0"
						           FontSize="20" Grid.Row="0"
						           HorizontalAlignment="Center"
						           VerticalAlignment="Center"
						           FontWeight="SemiBold"
						           Foreground="White"
						           FontFamily="{StaticResource Nunito}"
						           Text="{x:Static p:Resources.Refresh}" />
						<Button
							Grid.Row="0" Grid.Column="1" Cursor="Hand" Width="60" Height="60" Margin="10"
							HorizontalAlignment="Left" VerticalAlignment="Center"
							Template="{StaticResource ButtonTemplate}"
							Command="{Binding LoadNowCommand}">
							<fa:ImageAwesome PrimaryColor="#007EF9" Icon="Solid_Rotate" Margin="10" />
						</Button>

						<ToggleButton
							Grid.Row="0" Grid.Column="2" Cursor="Hand" Width="60" Height="60" Margin="10"
							HorizontalAlignment="Left" VerticalAlignment="Center"
							Template="{StaticResource ToggleButtonTemplate}">
							<i:Interaction.Triggers>
								<i:EventTrigger EventName="Checked">
									<i:InvokeCommandAction Command="{Binding Path=StopPassiveLoadAsyncCommand}" />
								</i:EventTrigger>
								<i:EventTrigger EventName="Unchecked">
									<i:InvokeCommandAction Command="{Binding Path=PassiveLoadAsyncCommand}" />
								</i:EventTrigger>
							</i:Interaction.Triggers>
							<fa:ImageAwesome PrimaryColor="#007EF9" Icon="Solid_Pause" Margin="10" />
						</ToggleButton>

						<TextBlock Margin="25" Grid.Row="1" Grid.Column="0"
						           FontSize="20"
						           HorizontalAlignment="Center"
						           VerticalAlignment="Center"
						           FontWeight="Normal"
						           Foreground="White"
						           FontFamily="{StaticResource Nunito}"
						           Text="{x:Static p:Resources.RefreshingIn}" />
						<TextBlock Margin="25" Grid.Row="1" Grid.ColumnSpan="2"
						           FontSize="20" Grid.Column="1"
						           HorizontalAlignment="Center"
						           FontFamily="{StaticResource Nunito}"
						           VerticalAlignment="Center"
						           FontWeight="Normal"
						           Foreground="#007EF9"
						           Text="{Binding RefreshTime}" />
					</Grid>
				</Border>
			</StackPanel>


		</Grid>

	</Grid>

</UserControl>