{
    "endpoints": [
        {
            "method": "GET",
            "name": "Gear",
            "url": "https://valorant-api.com/v1/gear",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {8}",
                        "uuid string",
                        "displayName string (localized)",
                        "description string (localized)",
                        "descriptions string[] (localized)",
                        "details object[] {2}",
                        "name string (localized)",
                        "value string (localized)",
                        "displayIcon string",
                        "assetPath string",
                        "shopData object {10}",
                        "cost int32",
                        "category string",
                        "shopOrderPriority int32",
                        "categoryText string (localized)",
                        "gridPosition object {2}",
                        "row int32",
                        "column int32",
                        "canBeTrashed boolean",
                        "image string",
                        "newImage string",
                        "newImage2 string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of all gear"
        },
        {
            "method": "GET",
            "name": "Gear by Uuid",
            "url": "https://valorant-api.com/v1/gear/{gearUuid}",
            "description": "",
            "parameters": [
                {
                    "name": "language",
                    "type": "string",
                    "description": "Sets the output language",
                    "default": "en-US",
                    "required": false
                }
            ],
            "responses": [
                {
                    "status_code": 200,
                    "description": "Success",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "data object[] {8}",
                        "uuid string",
                        "displayName string (localized)",
                        "description string (localized)",
                        "descriptions string[] (localized)",
                        "details object[] {2}",
                        "name string (localized)",
                        "value string (localized)",
                        "displayIcon string",
                        "assetPath string",
                        "shopData object {10}",
                        "cost int32",
                        "category string",
                        "shopOrderPriority int32",
                        "categoryText string (localized)",
                        "gridPosition object {2}",
                        "row int32",
                        "column int32",
                        "canBeTrashed boolean",
                        "image string",
                        "newImage string",
                        "newImage2 string",
                        "assetPath string"
                    ]
                },
                {
                    "status_code": 400,
                    "description": "Bad Request",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                },
                {
                    "status_code": 404,
                    "description": "Not Found",
                    "schema": [
                        "object {2}",
                        "status int32",
                        "error string"
                    ]
                }
            ],
            "info": "Returns data and assets of the requested gear"
        }
    ]
}