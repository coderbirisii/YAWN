                        "displayName string (localized)",
                        "narrativeDescription string (localized)",
                        "tacticalDescription string (localized)",
                        "coordinates string (localized)",
                        "displayIcon string",
                        "listViewIcon string",
                        "listViewIconTall string",
                        "splash string",
                        "stylizedBackgroundImage string",
                        "premierBackgroundImage string",
                        "assetPath string",
                        "mapUrl string",
                        "xMultiplier single",
                        "yMultiplier single",
                        "xScalarToAdd single",
                        "yScalarToAdd single",
                        "callouts object[] {6}",
                        "regionName string (localized)",
                        "superRegion string",
                        "superRegionName string (localized)",
                        "location object {3}",
                        "x single",
                        "y single",
                        "z single",
                        "scale3D object {3}",
                        "x single",
                        "y single",
                        "z single",
                        "rotation object {3}",
                        "pitch single",
                        "yaw single",
                        "roll single"
